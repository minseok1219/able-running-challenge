<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.crossfitable.arc-backup-nas-sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/leo/Documents/Playground &amp;&amp; npm run backup:nas-sync</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/leo/Documents/Playground</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Weekday</key>
      <integer>1</integer>
      <key>Hour</key>
      <integer>15</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/leo/Documents/Playground/backups/logs/backup-nas-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/leo/Documents/Playground/backups/logs/backup-nas-sync.error.log</string>

    <key>RunAtLoad</key>
    <false/>
  </dict>
</plist>
